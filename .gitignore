# ─────────────────────────────────────────────────────────────────────────────
# AI Story Buddy – Backend .gitignore
# Node.js / Express / macOS / Linux / Windows / editors
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.npm/
.yarn/
.pnp/
.pnp.js
.yarn-integrity

# ── Environment & secrets ─────────────────────────────────────────────────────
# Never commit real env files – only the .example template
.env


# ── Build / compiled output ───────────────────────────────────────────────────
dist/
build/
out/
.cache/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test & coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
junit.xml



# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/

# Emacs
*#
.\#*
.emacs.desktop
.emacs.desktop.lock
*.elc
auto-save-list
tramp

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

