# Server
PORT=4000
NODE_ENV=development

# CORS - comma separated list of allowed origins, or * for any
CORS_ORIGIN=*

# --- LLM provider (used for AI story generation & AI quiz generation) ---
# Supported: "anthropic" | "openai" | "none"
LLM_PROVIDER=none
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- TTS provider (used for /api/tts) ---
# Supported: "elevenlabs" | "none"
TTS_PROVIDER=none
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
